// Prisma Schema para MongoDB Atlas
// Proyecto: Sistema de Gestión Familiar Morcilla

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  ADMIN
  VENDEDOR
  COBRADOR
}

enum BatchStatus {
  ACTIVE
  CLOSED
}

enum PaymentMethod {
  EFECTIVO
  NEQUI
  TRANSFERENCIA
}

enum PaymentStatus {
  PAID      // Pagado inmediatamente
  PENDING   // A crédito
  PARTIAL   // Pago parcial
}

enum MovementType {
  INCOME  // Ingreso
  EXPENSE // Egreso
}



// Modelo de Usuario/Vendedor
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(VENDEDOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  sales         Sale[]
  cashMovements CashMovement[]
  collections   Collection[]
  expenses      Expense[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")

  @@map("users")
}

// Modelo de Tanda de Producción
model ProductionBatch {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  name           String      // "Tanda #15 - Nov 10"
  number         Int         @unique
  productionDate DateTime
  status         BatchStatus @default(ACTIVE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  closedAt       DateTime?

  // Relaciones
  sales       Sale[]
  collections Collection[]

  @@map("production_batches")
}

// Modelo de Cliente
model Customer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String?
  address     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  totalDebt   Float    @default(0)
  totalPaid   Float    @default(0)

  // Relaciones
  sales       Sale[]
  collections Collection[]

  @@map("customers")
}

// Modelo de Venta
model Sale {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  pounds        Float          // Cantidad de libras
  pricePerPound Float          // Precio por libra
  totalAmount   Float          // Monto total
  paymentMethod PaymentMethod? // Opcional para ventas a crédito
  paymentStatus PaymentStatus  @default(PENDING)
  saleDate      DateTime       @default(now())
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relaciones
  customerId String          @db.ObjectId
  customer   Customer        @relation(fields: [customerId], references: [id])
  userId     String          @db.ObjectId
  user       User            @relation(fields: [userId], references: [id])
  batchId    String          @db.ObjectId
  batch      ProductionBatch @relation(fields: [batchId], references: [id])

  @@map("sales")
}

// Modelo de Cobro (cuando se cobran ventas a crédito)
model Collection {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  amount         Float
  paymentMethod  PaymentMethod
  collectionDate DateTime         @default(now())
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relaciones
  customerId String          @db.ObjectId
  customer   Customer        @relation(fields: [customerId], references: [id])
  userId     String          @db.ObjectId
  user       User            @relation(fields: [userId], references: [id])
  batchId    String?         @db.ObjectId
  batch      ProductionBatch? @relation(fields: [batchId], references: [id])

  @@map("collections")
}

// Modelo de Movimientos de Caja por Usuario
model CashMovement {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  movementType  MovementType
  amount        Float
  paymentMethod PaymentMethod
  description   String
  movementDate  DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relaciones
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  @@map("cash_movements")
}

// Modelo de Transferencias Internas entre Usuarios
model Transfer {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  amount        Float
  paymentMethod PaymentMethod
  concept       String
  transferDate  DateTime      @default(now())
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relaciones
  fromUserId String @db.ObjectId
  fromUser   User   @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUserId   String @db.ObjectId
  toUser     User   @relation("TransferTo", fields: [toUserId], references: [id])

  @@map("transfers")
}

// Modelo de Gastos/Egresos
model Expense {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  amount      Float
  concept     String   // Concepto obligatorio
  description String?
  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  @@map("expenses")
}

